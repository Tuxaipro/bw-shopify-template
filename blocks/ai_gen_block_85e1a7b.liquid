{% doc %}
  @prompt
    Product information (with Media gallery + Product details blocks)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-info-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-product-info-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    align-items: start;
  }

  .ai-product-info-media-{{ ai_gen_id }} {
    position: sticky;
    top: 20px;
  }

  .ai-product-info-media-gallery-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.media_gap }}px;
  }

  .ai-product-info-media-item-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.media_background }};
  }

  .ai-product-info-media-item-{{ ai_gen_id }} img,
  .ai-product-info-media-item-{{ ai_gen_id }} video {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-info-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.media_border_radius }}px;
  }

  .ai-product-info-media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-info-details-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.details_gap }}px;
  }

  .ai-product-info-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    margin: 0;
    color: {{ block.settings.text_color }};
    font-family: var(--font-heading-family);
    line-height: 1.2;
  }

  .ai-product-info-vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-product-info-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-product-info-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    font-weight: 400;
  }

  .ai-product-info-price-sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_color }};
  }

  .ai-product-info-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-product-info-variants-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-product-info-variant-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-info-variant-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-product-info-variant-options-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-product-info-variant-option-{{ ai_gen_id }} {
    padding: 10px 20px;
    border: 1px solid {{ block.settings.variant_border_color }};
    border-radius: {{ block.settings.variant_border_radius }}px;
    background-color: {{ block.settings.variant_background }};
    color: {{ block.settings.text_color }};
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 14px;
  }

  .ai-product-info-variant-option-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.variant_hover_background }};
    border-color: {{ block.settings.variant_hover_border }};
  }

  .ai-product-info-variant-option-{{ ai_gen_id }}.selected {
    background-color: {{ block.settings.variant_selected_background }};
    border-color: {{ block.settings.variant_selected_border }};
    color: {{ block.settings.variant_selected_text }};
  }

  .ai-product-info-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-info-quantity-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-product-info-quantity-selector-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    border: 1px solid {{ block.settings.variant_border_color }};
    border-radius: {{ block.settings.variant_border_radius }}px;
    overflow: hidden;
  }

  .ai-product-info-quantity-button-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border: none;
    background-color: {{ block.settings.variant_background }};
    color: {{ block.settings.text_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease;
  }

  .ai-product-info-quantity-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.variant_hover_background }};
  }

  .ai-product-info-quantity-input-{{ ai_gen_id }} {
    width: 60px;
    height: 40px;
    border: none;
    text-align: center;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    background-color: transparent;
  }

  .ai-product-info-add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .ai-product-info-add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-product-info-add-to-cart-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-product-info-meta-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid {{ block.settings.variant_border_color }};
  }

  .ai-product-info-meta-item-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-info-meta-label-{{ ai_gen_id }} {
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-product-info-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
    }

    .ai-product-info-media-{{ ai_gen_id }} {
      position: static;
    }

    .ai-product-info-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-product-info-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<product-info-{{ ai_gen_id }} class="ai-product-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-info-container-{{ ai_gen_id }}">
    <div class="ai-product-info-media-{{ ai_gen_id }}">
      <div class="ai-product-info-media-gallery-{{ ai_gen_id }}">
        {% if product.media.size > 0 %}
          {% for media in product.media limit: block.settings.max_media %}
            <div class="ai-product-info-media-item-{{ ai_gen_id }}">
              {% if media.media_type == 'image' %}
                <img
                  src="{{ media | image_url: width: 1200 }}"
                  alt="{{ media.alt | escape }}"
                  loading="lazy"
                  width="{{ media.width }}"
                  height="{{ media.height }}"
                >
              {% elsif media.media_type == 'video' or media.media_type == 'external_video' %}
                {{ media | media_tag: image_size: '1200x', autoplay: true, loop: true, muted: true }}
              {% endif %}
            </div>
          {% endfor %}
        {% else %}
          <div class="ai-product-info-media-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-product-info-details-{{ ai_gen_id }}">
      {% if block.settings.show_vendor and product.vendor != blank %}
        <p class="ai-product-info-vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
      {% endif %}

      <h1 class="ai-product-info-title-{{ ai_gen_id }}">{{ product.title }}</h1>

      <div class="ai-product-info-price-{{ ai_gen_id }}">
        {% if product.compare_at_price > product.price %}
          <span class="ai-product-info-price-compare-{{ ai_gen_id }}">
            {{ product.compare_at_price | money }}
          </span>
          <span class="ai-product-info-price-sale-{{ ai_gen_id }}">
            {{ product.price | money }}
          </span>
        {% else %}
          <span>{{ product.price | money }}</span>
        {% endif %}
      </div>

      {% if block.settings.show_description and product.description != blank %}
        <div class="ai-product-info-description-{{ ai_gen_id }}">
          {{ product.description }}
        </div>
      {% endif %}

      {% if product.has_only_default_variant == false %}
        <div class="ai-product-info-variants-{{ ai_gen_id }}">
          {% for option in product.options_with_values %}
            <div class="ai-product-info-variant-group-{{ ai_gen_id }}">
              <label class="ai-product-info-variant-label-{{ ai_gen_id }}">
                {{ option.name }}
              </label>
              <div class="ai-product-info-variant-options-{{ ai_gen_id }}">
                {% for value in option.values %}
                  <button
                    type="button"
                    class="ai-product-info-variant-option-{{ ai_gen_id }} {% if option.selected_value == value %}selected{% endif %}"
                    data-option-name="{{ option.name }}"
                    data-option-value="{{ value }}"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if block.settings.show_quantity %}
        <div class="ai-product-info-quantity-{{ ai_gen_id }}">
          <span class="ai-product-info-quantity-label-{{ ai_gen_id }}">Quantity</span>
          <div class="ai-product-info-quantity-selector-{{ ai_gen_id }}">
            <button type="button" class="ai-product-info-quantity-button-{{ ai_gen_id }}" data-action="decrease">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="4" y1="8" x2="12" y2="8"></line>
              </svg>
            </button>
            <input
              type="number"
              class="ai-product-info-quantity-input-{{ ai_gen_id }}"
              value="1"
              min="1"
              readonly
            >
            <button type="button" class="ai-product-info-quantity-button-{{ ai_gen_id }}" data-action="increase">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="8" y1="4" x2="8" y2="12"></line>
                <line x1="4" y1="8" x2="12" y2="8"></line>
              </svg>
            </button>
          </div>
        </div>
      {% endif %}

      <button
        type="button"
        class="ai-product-info-add-to-cart-{{ ai_gen_id }}"
        {% unless product.available %}disabled{% endunless %}
      >
        {% if product.available %}
          {{ block.settings.add_to_cart_text }}
        {% else %}
          Sold out
        {% endif %}
      </button>

      {% if block.settings.show_meta %}
        <div class="ai-product-info-meta-{{ ai_gen_id }}">
          {% if product.type != blank %}
            <div class="ai-product-info-meta-item-{{ ai_gen_id }}">
              <span class="ai-product-info-meta-label-{{ ai_gen_id }}">Type:</span>
              <span>{{ product.type }}</span>
            </div>
          {% endif %}
          {% if product.tags.size > 0 %}
            <div class="ai-product-info-meta-item-{{ ai_gen_id }}">
              <span class="ai-product-info-meta-label-{{ ai_gen_id }}">Tags:</span>
              <span>{{ product.tags | join: ', ' }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</product-info-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductInfo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.product = {{ product | json }};
        this.selectedOptions = {};
        this.quantity = 1;
      }

      connectedCallback() {
        this.initializeSelectedOptions();
        this.setupEventListeners();
      }

      initializeSelectedOptions() {
        if (this.product.options && this.product.options.length > 0) {
          this.product.options.forEach((option, index) => {
            const selectedValue = this.product.selected_or_first_available_variant.options[index];
            this.selectedOptions[option] = selectedValue;
          });
        }
      }

      setupEventListeners() {
        const variantButtons = this.querySelectorAll('.ai-product-info-variant-option-{{ ai_gen_id }}');
        variantButtons.forEach(button => {
          button.addEventListener('click', (e) => this.handleVariantChange(e));
        });

        const quantityButtons = this.querySelectorAll('.ai-product-info-quantity-button-{{ ai_gen_id }}');
        quantityButtons.forEach(button => {
          button.addEventListener('click', (e) => this.handleQuantityChange(e));
        });

        const addToCartButton = this.querySelector('.ai-product-info-add-to-cart-{{ ai_gen_id }}');
        if (addToCartButton) {
          addToCartButton.addEventListener('click', () => this.handleAddToCart());
        }
      }

      handleVariantChange(event) {
        const button = event.currentTarget;
        const optionName = button.dataset.optionName;
        const optionValue = button.dataset.optionValue;

        this.selectedOptions[optionName] = optionValue;

        const optionButtons = this.querySelectorAll(`[data-option-name="${optionName}"]`);
        optionButtons.forEach(btn => btn.classList.remove('selected'));
        button.classList.add('selected');

        this.updateVariant();
      }

      updateVariant() {
        const selectedVariant = this.product.variants.find(variant => {
          return variant.options.every((option, index) => {
            return option === this.selectedOptions[this.product.options[index]];
          });
        });

        if (selectedVariant) {
          this.currentVariant = selectedVariant;
          this.updatePrice(selectedVariant);
          this.updateAvailability(selectedVariant);
        }
      }

      updatePrice(variant) {
        const priceContainer = this.querySelector('.ai-product-info-price-{{ ai_gen_id }}');
        if (!priceContainer) return;

        const price = variant.price;
        const compareAtPrice = variant.compare_at_price;

        if (compareAtPrice && compareAtPrice > price) {
          priceContainer.innerHTML = `
            <span class="ai-product-info-price-compare-{{ ai_gen_id }}">
              ${this.formatMoney(compareAtPrice)}
            </span>
            <span class="ai-product-info-price-sale-{{ ai_gen_id }}">
              ${this.formatMoney(price)}
            </span>
          `;
        } else {
          priceContainer.innerHTML = `<span>${this.formatMoney(price)}</span>`;
        }
      }

      updateAvailability(variant) {
        const addToCartButton = this.querySelector('.ai-product-info-add-to-cart-{{ ai_gen_id }}');
        if (!addToCartButton) return;

        if (variant.available) {
          addToCartButton.disabled = false;
          addToCartButton.textContent = '{{ block.settings.add_to_cart_text }}';
        } else {
          addToCartButton.disabled = true;
          addToCartButton.textContent = 'Sold out';
        }
      }

      handleQuantityChange(event) {
        const action = event.currentTarget.dataset.action;
        const input = this.querySelector('.ai-product-info-quantity-input-{{ ai_gen_id }}');

        if (action === 'increase') {
          this.quantity++;
        } else if (action === 'decrease' && this.quantity > 1) {
          this.quantity--;
        }

        input.value = this.quantity;
      }

      handleAddToCart() {
        const variantId = this.currentVariant ? this.currentVariant.id : this.product.variants[0].id;

        const formData = {
          items: [{
            id: variantId,
            quantity: this.quantity
          }]
        };

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
          window.location.href = '/cart';
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
        });
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}'
        }).format(amount);
      }
    }

    customElements.define('product-info-{{ ai_gen_id }}', ProductInfo{{ ai_gen_id }});
  })();
</script>

