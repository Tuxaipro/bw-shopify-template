<script>
  (function applyPageflyColorSwatchFix() {
    const colorNameMap = {
      navy: '#2f3f4f',
      blue: '#1976d2',
      teal: '#0a8b89',
      green: '#2f9e44',
      red: '#8d8d8d',
      orange: '#f57c49',
      pink: '#e7a8b8',
      purple: '#ce6dd6',
      violet: '#a362d9',
      yellow: '#f2c84b',
      black: '#263745',
      white: '#f3f3f3',
      grey: '#8f8f8f',
      gray: '#8f8f8f',
      cream: '#efe6d5',
      gold: '#d9bd74',
      maroon: '#8b1e0e',
    };

    const toCssColor = (raw) => {
      if (!raw) return '#b8b8b8';
      const normalized = raw.toLowerCase().trim();

      for (const [key, value] of Object.entries(colorNameMap)) {
        if (normalized.includes(key)) return value;
      }

      const probe = document.createElement('span');
      probe.style.color = normalized;
      return probe.style.color ? normalized : '#b8b8b8';
    };

    const optionGroups = document.querySelectorAll('[data-pf-type="ProductVariantSwatches"] .pf-option-swatches');

    optionGroups.forEach((group) => {
      const previousLabel = group.previousElementSibling;
      const isColorOption = previousLabel && previousLabel.textContent && previousLabel.textContent.toLowerCase().includes('color');

      if (!isColorOption) return;

      if (group.dataset.swatchType === 'radio') {
        group.classList.add('pf-option-swatches--colorized');
      }

      group.querySelectorAll('label > span').forEach((span) => {
        const source = span.getAttribute('title') || span.textContent || '';
        span.style.setProperty('--pf-swatch-bg', toCssColor(source));
      });
    });
  })();
</script>
