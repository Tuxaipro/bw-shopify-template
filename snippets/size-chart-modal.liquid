{% comment %}
  US-focused size chart modal (Idea.md §9). Opens via .breezy-size-chart-open
{% endcomment %}
<dialog id="BreezySizeChartModal" class="breezy-size-chart-dialog" aria-labelledby="breezy-size-chart-title">
  <div class="breezy-size-chart-dialog__header">
    <h2 id="breezy-size-chart-title">Size chart (inches)</h2>
    <button type="button" class="button button-secondary breezy-size-chart-close" aria-label="{{ 'accessibility.close_dialog' | t }}">
      {{ 'actions.close' | t }}
    </button>
  </div>
  <div class="breezy-size-chart-dialog__body">
    <p class="breezy-size-chart-dialog__note">
      Measurements are body measurements. Indian wear varies by cut—when between sizes, size up for a relaxed fit. Replace these numbers in this snippet when your final chart is ready.
    </p>

    <div class="breezy-size-chart-table-wrap">
      <h3>Kurti / top (inches)</h3>
      <table class="breezy-size-chart-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Bust</th>
            <th>Waist</th>
            <th>Hip</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>S</td><td>34–35</td><td>28–29</td><td>36–37</td></tr>
          <tr><td>M</td><td>36–37</td><td>30–31</td><td>38–39</td></tr>
          <tr><td>L</td><td>38–39</td><td>32–33</td><td>40–41</td></tr>
          <tr><td>XL</td><td>40–41</td><td>34–35</td><td>42–43</td></tr>
          <tr><td>XXL</td><td>42–43</td><td>36–37</td><td>44–45</td></tr>
          <tr><td>XXXL</td><td>44–46</td><td>38–40</td><td>46–48</td></tr>
        </tbody>
      </table>
    </div>

    <div class="breezy-size-chart-table-wrap">
      <h3>Lehenga skirt (waist / length)</h3>
      <table class="breezy-size-chart-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Waist</th>
            <th>Length</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>S</td><td>28–29</td><td>40</td></tr>
          <tr><td>M</td><td>30–31</td><td>41</td></tr>
          <tr><td>L</td><td>32–33</td><td>41</td></tr>
          <tr><td>XL</td><td>34–35</td><td>42</td></tr>
          <tr><td>XXL</td><td>36–37</td><td>42</td></tr>
          <tr><td>XXXL</td><td>38–40</td><td>43</td></tr>
        </tbody>
      </table>
    </div>

    <div class="breezy-size-chart-table-wrap">
      <h3>Dress (inches)</h3>
      <table class="breezy-size-chart-table">
        <thead>
          <tr>
            <th>Size</th>
            <th>Bust</th>
            <th>Waist</th>
            <th>Hip</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>S</td><td>34</td><td>27</td><td>36</td></tr>
          <tr><td>M</td><td>36</td><td>29</td><td>38</td></tr>
          <tr><td>L</td><td>38</td><td>31</td><td>40</td></tr>
          <tr><td>XL</td><td>40</td><td>33</td><td>42</td></tr>
          <tr><td>XXL</td><td>42</td><td>35</td><td>44</td></tr>
          <tr><td>XXXL</td><td>44</td><td>37</td><td>46</td></tr>
        </tbody>
      </table>
    </div>

    <p class="breezy-size-chart-dialog__note"><strong>How to measure:</strong> bust at fullest, waist at narrowest, hip at fullest. For saree blouses, add 1–2&quot; ease to bust if you prefer a comfort fit.</p>
  </div>
</dialog>

<script>
  (function () {
    var dialog = document.getElementById('BreezySizeChartModal');
    if (!dialog || typeof dialog.showModal !== 'function') return;

    document.addEventListener('click', function (e) {
      var t = e.target;
      if (!t || !t.closest) return;
      if (t.closest('.breezy-size-chart-open')) {
        e.preventDefault();
        dialog.showModal();
      }
      if (t.closest('.breezy-size-chart-close')) {
        e.preventDefault();
        dialog.close();
      }
    });
  })();
</script>
