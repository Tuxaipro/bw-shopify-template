{% comment %}
  Floating WhatsApp concierge button — configured under Theme settings → Breezyweaves store.
{% endcomment %}
{% liquid
  assign wa_url = settings.breezyweaves_whatsapp_url
  assign show_btn = settings.breezyweaves_show_whatsapp_button
%}
{% if show_btn and wa_url != blank %}
  <a
    class="breezyweaves-whatsapp-float"
    href="{{ wa_url }}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="{{ 'accessibility.whatsapp_contact' | t }}"
  >
    <span class="breezyweaves-whatsapp-float__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" focusable="false">
        {%- render 'icon', icon: 'whatsapp' -%}
      </svg>
    </span>
  </a>
  <style>
    .breezyweaves-whatsapp-float {
      position: fixed;
      z-index: 40;
      right: max(1rem, env(safe-area-inset-right));
      bottom: max(1rem, env(safe-area-inset-bottom));
      display: grid;
      place-items: center;
      width: 3.25rem;
      height: 3.25rem;
      border-radius: 9999px;
      background: #25d366;
      color: #fff;
      box-shadow: 0 0.35rem 1.25rem rgb(0 0 0 / 0.22);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .breezyweaves-whatsapp-float:hover {
      transform: scale(1.04);
      box-shadow: 0 0.5rem 1.5rem rgb(0 0 0 / 0.28);
    }
    .breezyweaves-whatsapp-float__icon {
      display: flex;
      width: 1.65rem;
      height: 1.65rem;
    }
    .breezyweaves-whatsapp-float__icon svg {
      width: 100%;
      height: 100%;
    }
  </style>
{% endif %}
