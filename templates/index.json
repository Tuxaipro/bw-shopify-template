    "custom_fabric_story": {
      "type": "custom-liquid",
      "name": "Our fabrics",
      "settings": {
        "custom_liquid": "\n<div class=\"breezy-fabric-story\">\n  <h2 class=\"breezy-fabric-story__title\">Our fabrics</h2>\n  <p class=\"breezy-fabric-story__lede\">Breathable materials chosen for drape, comfort, and quiet luxury.</p>\n  <div class=\"breezy-fabric-grid\">\n    <article class=\"breezy-fabric-card\"><h3>Silk</h3><p>Natural sheen and fluid movement for celebrations and evenings out.</p></article>\n    <article class=\"breezy-fabric-card\"><h3>Cotton</h3><p>Soft, airy, and easy\u2014ideal for everyday kurtis and relaxed silhouettes.</p></article>\n    <article class=\"breezy-fabric-card\"><h3>Crepe</h3><p>Lightweight texture that skims the body with a refined matte finish.</p></article>\n    <article class=\"breezy-fabric-card\"><h3>Viscose</h3><p>Fluid drape with a gentle hand\u2014perfect for travel-friendly pieces.</p></article>\n    <article class=\"breezy-fabric-card\"><h3>Georgette</h3><p>Sheer structure with graceful flow for layered and Indo-western looks.</p></article>\n  </div>\n</div>\n",
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 32,
        "padding-block-end": 40
      }
    },
    "custom_instagram_cta": {
      "type": "custom-liquid",
      "name": "Instagram",
      "settings": {
        "custom_liquid": "\n<div class=\"breezy-instagram-cta\">\n  <h2>On Instagram</h2>\n  <p>Follow <a href=\"https://www.instagram.com/breezy_weaves\" target=\"_blank\" rel=\"noopener\">@breezy_weaves</a> for new drops, styling ideas, and behind-the-scenes.</p>\n  <a class=\"button\" href=\"https://www.instagram.com/breezy_weaves\" target=\"_blank\" rel=\"noopener\">View on Instagram</a>\n  <p class=\"breezy-instagram-cta__note\">Tip: add an Instagram sales channel app later for a live feed.</p>\n</div>\n",
        "color_scheme": "scheme-2",
        "section_width": "page-width",
        "padding-block-start": 24,
        "padding-block-end": 56
      }
    }
